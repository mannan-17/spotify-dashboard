# 1. Create an app at https://developer.spotify.com/dashboard
#    (register redirect URI http://127.0.0.1:8501 — used only by the
#     one-time mint_refresh_token.py login, never at runtime)
# 2. Copy this file to ".env" and paste your values below.
# 3. Run `python mint_refresh_token.py` once — it appends
#    SPOTIPY_REFRESH_TOKEN here automatically.
# 4. Keep .env private — never commit it.

SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8501
